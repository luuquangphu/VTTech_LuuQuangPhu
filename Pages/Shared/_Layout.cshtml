<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRUDCustomer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CRUDCustomer.styles.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
        }

        header {
            height: 56px;
            z-index: 1031;
        }

        #sidebarMenu {
            height: calc(100vh - 56px);
            overflow-y: auto;
            background-color: #f8f9fa;
            transition: all 0.3s ease-in-out;
            width: 250px;
            flex: 0 0 250px;
        }

        #sidebarMenu.closed {
            margin-left: -250px;
        }

        main {
            height: calc(100vh - 56px);
            overflow-y: auto;
            overflow-x: hidden;
            flex: 1;
            transition: all 0.3s ease-in-out;
            display: flex;
            flex-direction: column;
        }

        .wrapper {
            display: flex;
            margin-top: 56px;
        }

        .content-area {
            flex: 1 0 auto;
            padding: 20px 0;
        }

        footer {
            flex-shrink: 0;
            background-color: #fff;
        }

        .navbar-toggler:focus,
        .navbar-toggler:active {
            outline: none !important;
            box-shadow: none !important;
        }

        .nav-link.has-child .icon-close {
            display: none;
        }

        .nav-link.has-child:not(.collapsed) .icon-main {
            display: none; 
        }

        .nav-link.has-child .icon-close {
            display: none;
        }

        .nav-link.has-child.collapsed .icon-main {
            display: inline-block;
        }

        .nav-link.has-child:not(.collapsed) .icon-main {
            display: none; 
        }

        .nav-link.has-child:not(.collapsed) .icon-close {
            display: inline-block;
            color: #000;
        }

        .icon-main, .icon-close {
            font-size: 1.0rem;
            font-weight: 900;
            animation: fadeIn 0.2s ease;
        }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .sub-menu {
            padding-left: 2.5rem;
            list-style: none;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <header class="fixed-top shadow-sm">
        <nav class="navbar navbar-light bg-white border-bottom">
            <div class="px-4 d-flex align-items-center">
                <button class="navbar-toggler me-3 border border-1 border-secondary" type="button" onclick="toggleSidebar()">
                    <span class="navbar-toggler-icon" style= "width: 25px; height: 25px"></span>
                </button>
                <a class="navbar-brand mb-0" asp-area="" asp-page="/Index">CRUDCustomer</a>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <div class="wrapper">
            <nav id="sidebarMenu" class="border-end shadow-sm">
                <div class="pt-3 mx-3">
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold py-3 has-child collapsed d-flex align-items-center"
                               data-bs-toggle="collapse"
                               href="#customerSubMenu">

                                <div class="me-2" style="width: 25px; text-align: center;">
                                    <i class="bi bi-plus-lg icon-main"></i>
                                    <i class="bi bi-dash-lg icon-close"></i>
                                </div>
                                <span>Customer</span>
                            </a>

                            <div class="collapse" id="customerSubMenu">
                                <ul class="nav flex-column sub-menu border-start ms-4">
                                    <li class="nav-item">
                                        <a class="nav-link text-muted py-2" asp-page="/CustomerDashBoard/CustomerDashBoard">Dashboard</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link text-muted py-2" asp-page="/Customer/CustomerList">CRUD Customer</a>
                                    </li>
                                </ul>
                            </div>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold py-3 has-child collapsed d-flex align-items-center"
                               data-bs-toggle="collapse"
                               href="#serviceSubMenu">

                                <div class="me-2" style="width: 25px; text-align: center;">
                                    <i class="bi bi-plus-lg icon-main"></i>
                                    <i class="bi bi-dash-lg icon-close"></i>
                                </div>
                                <span>Services</span>
                            </a>

                            <div class="collapse" id="serviceSubMenu">
                                <ul class="nav flex-column sub-menu border-start ms-4">
                                    <li class="nav-item">
                                        <a class="nav-link text-muted py-2" asp-page="/Service/ServiceList">CRUD Services</a>
                                    </li>
                                </ul>
                            </div>
                        </li>
                    </ul>
                </div>
            </nav>

            <main class="px-md-4">
                <div class="content-area p-3">
                    @RenderBody()
                </div>

                <footer class="py-3 text-muted border-top">
                    <div class="container-fluid">
                        &copy; 2026 - CRUDCustomer - <a asp-area="" asp-page="/Privacy">Privacy</a>
                    </div>
                </footer>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebarMenu');
            sidebar.classList.toggle('closed');
        }
    </script>

    @* ĐÂY LÀ DÒNG CÒN THIẾU ĐỂ SỬA LỖI EXCEPTION *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>