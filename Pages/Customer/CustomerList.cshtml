@page
@model CRUDCustomer.Pages.Customer.CustomerListModel
@{
    ViewData["Title"] = "Customer List";
}
<button type="button" class="btn btn-primary mb-3" onclick="OpenModal('0')">
    Thêm khách hàng mới
</button>
<div class="table-responsive overflow-auto shadow-sm border rounded mb-3" style="max-height: 550px;">
    <table class="table table-hover mb-0">
        <thead class="table-light sticky-top" style="z-index: 1;">
            <tr>
                <th>STT</th>
                <th>CusID</th>
                <th>Name</th>
                <th>SDT</th>
                <th>Ghi chú</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody id="lstCustomer"></tbody>
    </table>
</div>

<div id="waitingDiv" class="waitingdiv text-center my-3" style="display: none">
    <div class="spinner-border text-primary" role="status"></div>
</div>
<div class="text-center mt-3 mb-5">
    <button id="btnLoadMore" class="btn btn-secondary px-5" style="display:none;" onclick="LoadLstCustomer()">
        Xem thêm
    </button>
</div>

<div class="modal fade" id="mainModal" tabindex="-1">
    <div class="modal-dialog modal-lg bg-white">
        <div class="modal-content" id="mainModalContent">
            <div class="text-center p-4">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2">Đang tải form...</div>
            </div>
        </div>
    </div>
</div>


@Html.AntiForgeryToken()

@section Scripts{
    <script>
        let limit = 10;
        let currentID = 0;
        let data;
        let currentEditID = 0;

        $(document).ready(function () {
            LoadLstCustomer(1);
        });

        function request(url, data, async, error, success, before, complete) {
            $.ajax({
                type: "POST",
                url: url,
                data: data,
                async: async,
                beforeSend: function (xhr) {
                    xhr.setRequestHeader("RequestVerificationToken",
                        $('input:hidden[name="__RequestVerificationToken"]').val());
                    if (before) before();
                },
                success: function (response) {
                    if (success) success(response);
                },
                error: function (err) {
                    if (error) error(err);
                    else console.error("Ajax Error:", err);
                },
                complete: function () {
                    if (complete) complete();
                }
            });
        };

        function LoadLstCustomer() {
            data = [];
            request(
                url = "/Customer/CustomerList/?handler=LoadDataList"
                , data = 
                {
                    "CurrentID": currentID
                    , "Limit": limit 
                }
                , async = true
                , error = null
                , success = function (result) {
                    if (result != "[]") {
                        data = JSON.parse(result);
                        let tbody = $('#lstCustomer');

                        let htmlRowsData = '';
                        for (let i = 0; i < data.length; i++) {
                            let item = data[i];

                            htmlRowsData += RenderData(data[i]);
                        }
                        tbody.append(htmlRowsData);

                        //Update currentID
                        currentID = data[data.length - 1].ID;

                        if (data.length < limit) {
                            $("#btnLoadMore").hide();
                        } else {
                            $("#btnLoadMore").show();
                        }

                    } else if (result == "0") {
                        alert("Có lỗi xảy ra khi tải dữ liệu từ máy chủ.");
                    } else {
                        if (lastLoadedID === 0) {
                            $('#lstCustomer').html("<tr><td colspan='6' class='text-center'>Không có dữ liệu</td></tr>");
                        }
                        $("#btnLoadMore").hide();
                        $("#waitingDiv").hide();
                    }

                }
                , before = function (){
                    $("#waitingDiv").show();
                }
                , complete = function (){
                    $("#waitingDiv").hide();
                }
            )
        };

        function RenderData(item) {
            try {
                let tr = `
                        <tr id="row_customer_${item.ID}" class="customer-row" data-ID="${item.ID}">
                            <td>${item.ID}</td>
                            <td>${item.Cust_Code}</td>
                            <td>${item.Name || ""}</td>
                            <td>${item.Phone1 || ""}</td>
                            <td>${item.Note || ""}</td>
                            <td>
                                <Button type="button" class="btn btn-warning" onclick="OpenModal('${item.ID}')">Sửa</Button>
                                <Button class="btn btn-danger" onclick="DeleteCustomer(event, '${item.ID}', '${item.Cust_Code}')" >Xóa</Button>
                            </td>
                        </tr>
                `;
                return tr;
            }
            catch (ex) {
                return ''
            }
        };

        function DeleteCustomer(e, ID, CustCode) {
            //Chặn mở modal khi nhấn vào button xóa vì sự kiện mở modal(click) được gán vào thẻ tr
            e.stopPropagation();

            let isConfirm = confirm("Bạn muốn xóa khách hàng có mã: " + CustCode + " không ?");

            if (isConfirm){
                request
                (
                    url = "/Customer/CustomerList/?handler=DeleteItem"
                    , data = { "ID": ID }
                    , async = true
                    , error = null
                    , success = function (result) {
                        if (result != "0") {
                            alert("Xóa khách hàng " + CustCode + " thành công!");
                            $(`#row_customer_${ID}`).remove();
                        }
                    }
                    , before = null
                    , complete = null
                )
            }
        };

        function OpenModal(id) {
            currentEditID = id;

            $('#mainModal').modal('show');

            $('#mainModalContent').load('/Customer/CustomerDetail?CurrentID=' + id, function (response, status) {
                if (status === "error") {
                    alert("Lỗi không thể tải được form!");
                    $('#mainModal').modal('hide');
                }
            });
        };

    </script>
}
