@page
@model CRUDCustomer.Pages.CustomerDashBoard.CustomerDashBoardModel
@{
    ViewData["Title"] = "Customer DashBoard";
}

<style>
    @@media (max-width: 480px){
        .card-containner {
            margin: 10px 0px 24px 0px;
            justify-content: start !important;
        }

        .toolbar-right {
            margin-left: 0 !important;
            width: 100%;
            justify-content: center;
            margin-top: 10px;
        }

        .toolbar-row {
            justify-content: center;
            padding: 0px !important;
        }
    } 

    .glass-date {
        position: relative;
        width: 300px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0px 12px 0px 18px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 2px solid #87cefa;
        box-shadow: 0 2px 10px rgba(135, 206, 250, 0.25);
        transition: 0.3s;
    }

    .glass-date:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 14px rgba(135, 206, 250, 0.35);
    }

    .glass-date input {
        width: 100%;
        background: transparent;
        border: none;
        outline: none;
        color: #1e293b;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        letter-spacing: 0.3px;
    }

    .glass-date input::placeholder {
        color: #94a3b8;
    }

    .calendar-icon {
        font-size: 18px;
        cursor: pointer;
        margin-left: 10px;
        flex-shrink: 0;
    }


    .btn-export:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }

    .spin-icon {
        animation: spin 0.9s linear infinite;
    }

    .toolbar-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin: 50px 0px 15px 0px;
        padding-left: 30px;
        padding-right: 30px;
    }

    .toolbar-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }



    .flatpickr-calendar {
        width: 310px !important;
        background: linear-gradient(to top, #87cefa, white) !important;
        backdrop-filter: blur(20px);
        border-radius: 20px !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        margin-top: 8px;
    }

    .flatpickr-day.selected,
    .flatpickr-day.startRange,
    .flatpickr-day.endRange {
        background: #4682b4 !important;
        color: white !important;
        border: none !important;
        border-radius: 50% !important;
    }

    .flatpickr-day.inRange {
        background: rgba(70, 130, 180, 0.25) !important;
        color: #1a1a2e !important;
        border-radius: 0 !important;
        box-shadow: -5px 0 0 rgba(70, 130, 180, 0.25), 5px 0 0 rgba(70, 130, 180, 0.25) !important;
        border: none !important;
    }

    .flatpickr-day.startRange {
        border-radius: 50% 0 0 50% !important;
    }

    .flatpickr-day.endRange {
        border-radius: 0 50% 50% 0 !important;
    }

    .flatpickr-day.startRange.endRange {
        border-radius: 50% !important;
    }

    .flatpickr-day:hover {
        background: #4682b4;
    }

    .flatpickr-innerContainer { justify-content: center; }

    .flatpickr-months { 
        border-radius: 20px 20px 0 0 !important; overflow: hidden;
    }

    .flatpickr-months,
    .flatpickr-weekdays,
    .flatpickr-weekday {
        background: transparent !important;
        color: #1a1a2e !important;
    }

    .flatpickr-months .flatpickr-month {
        background: transparent !important;
        color: #1a1a2e !important;
        fill: #1a1a2e !important;
    }

    .flatpickr-current-month,
    .flatpickr-current-month input.cur-year { color: #1a1a2e !important; }

    .flatpickr-months .flatpickr-prev-month,
    .flatpickr-months .flatpickr-next-month { fill: #1a1a2e !important; color: #1a1a2e !important; }

    .flatpickr-day { color: black !important; }

    .flatpickr-day:hover { background: rgba(255,255,255,0.4) !important; color: #1a1a2e !important; }

    .flatpickr-day.flatpickr-disabled,
    .flatpickr-day.prevMonthDay,
    .flatpickr-day.nextMonthDay { color: rgba(7,7,7,0.35) !important; }

    .flatpickr-monthDropdown-months { 
        background-color: white !important; 
    }

    .flatpickr-current-month .flatpickr-monthDropdown-months .flatpickr-monthDropdown-month {
        background-color: white !important;
        outline: none;
        padding: 0;
    }

    .btn:focus, .btn:active {
        box-shadow: none !important;
        outline: none !important;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/light.css">

<div class="dashboard-wrapper">

    <div class="container-fluid mt-2 mb-2" style="padding: 0px !important">
        <div class="row">
            <div class="col-12 col-md-4 mb-3">
                <div class="card h-100 shadow border-0 border-start border-5 border-primary rounded-3 pt-2" style="height: 150px;">
                    <div class="card-body py-3 d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-uppercase fw-bold mb-2">Tổng khách hàng</h6>
                            <h3 class="fw-bold text-dark mb-0" id="cardTotalCustomer">--</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-2 d-flex align-items-center justify-content-center">
                            <img width="40" height="40" src="https://img.icons8.com/pastel-glyph/64/gender-neutral-user.png" alt="gender-neutral-user" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 mb-3">
                <div class="card h-100 shadow border-0 border-start border-5 border-success rounded-3 pt-2" style="height: 150px;">
                    <div class="card-body py-3 d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-uppercase fw-bold mb-2">Doanh số</h6>
                            <h3 class="fw-bold text-dark mb-0" id="cardSale">--đ</h3>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-2 d-flex align-items-center justify-content-center">
                            <img width="40" height="40" src="https://img.icons8.com/wired/64/sale-price-tag.png" alt="sale-price-tag" />
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-4 mb-3">
                <div class="card h-100 shadow border-0 border-start border-5 border-info rounded-3 pt-2" style="height: 100px;">
                    <div class="card-body py-3 d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-uppercase fw-bold mb-2">Doanh thu</h6>
                            <h3 class="fw-bold text-dark mb-0" id="cardRevenue">--đ</h3>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-2 d-flex align-items-center justify-content-center">
                            <img width="40" height="40" src="https://img.icons8.com/pastel-glyph/64/stocks-growth.png" alt="stocks-growth" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <p class="text-secondary mt-3" style="font-size: 16px;">Bảng điều khiển khách hàng - Quản lý và theo dõi thông tin, doanh thu, dịch vụ của khách hàng.</p>

    <div class="toolbar-row" style="padding: 0px !important; margin: 10px 0px 10px 0px !important">    
        <div class="d-flex align-items-center gap-2">
            <select class="form-select shadow-sm border-1 border-secondary text-dark fw-medium w-auto" id="selectExample" style="height: 40px;">
                <option value="0" selected>Hôm nay</option>
                <option value="1">1 tháng</option>
                <option value="3">3 tháng</option>
                <option value="6">6 tháng</option>
            </select>
            <div class="glass-date">
                <input type="text" id="datePicker" placeholder="Chọn ngày..." readonly>
                <span class="calendar-icon" onclick="fpInstance && fpInstance.open()">📅</span>
            </div>
        </div>

        <button id="btnLichHen" class="btn btn-secondary text-secondary bg-white fw-semibold border-1 d-inline-flex align-items-center gap-2">
            <img width="20" height="20" src="https://img.icons8.com/quill/100/calendar.png" alt="calendar" />
            Lịch hẹn
        </button>
        <button id="btnDichVu" class="btn btn-secondary text-secondary bg-white fw-semibold border-1 d-inline-flex align-items-center gap-2">
            <img width="20" height="20" src="https://img.icons8.com/ios/50/clipboard.png" alt="clipboard" />
            Dịch vụ
        </button>
        <button id="btnThanhToan" class="btn btn-secondary text-secondary bg-white fw-semibold border-1 d-inline-flex align-items-center gap-2">
            <img width="20" height="20" src="https://img.icons8.com/ios/50/bank-card-back-side--v1.png" alt="bank-card-back-side--v1" />
            Thanh toán
        </button>

        <div class="toolbar-right">
            <div class="btn-group shadow-sm" role="group">
                <div class="btn btn-white border-1 border-secondary bg-white text-dark fw-semibold" style="cursor: default; pointer-events: none;">
                    SL: <span class="fw-bold text-primary" id="itemCount">0</span>
                </div>
                <button id="btnExportExcel" class="btn btn-secondary bg-white text-black border-1 fw-semibold d-inline-flex align-items-center gap-2">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.0" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="position-relative">
        <div class="table-responsive bg-white shadow-sm border rounded-3 mb-4" style="max-height: 450px; overflow-y: auto;">
            <table class="table table-bordered table-hover align-middle mb-0" id="customerTable">
                <thead class="table-light sticky-top" style="z-index: 1;">
                    <tr>
                        <th class="text-center" style="width: 50px;">#</th>
                        <th class="text-uppercase" style="font-size: 13px;">Khách hàng</th>
                        <th class="text-uppercase" style="font-size: 13px;">Liên hệ</th>
                    </tr>
                </thead>
                <tbody id="lstCustomer"></tbody>
            </table>
        </div>
    </div>

    <div class="text-center mt-3 mb-4">
        <button id="btnLoadMore" class="btn btn-secondary position-relative" style="display:none; min-width: 160px;" onclick="LoadList(0, 1)">
            <span id="waitingDiv" class="spinner-border spinner-border-sm text-light position-absolute top-50 start-0 translate-middle-y ms-3" role="status" style="display: none;"></span>
            <span>Xem thêm</span>
        </button>
    </div>

</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
    <script>
        let beginID       = 0;
        let dataList      = [];
        let limit         = 5;
        let isDoneLoadMore = false;
        let currentType   = 1;          // 1=Date | 2=LịchHẹn | 3=DịchVụ | 4=ThanhToán
        let fpInstance    = null;       

        $(document).ready(function () {
        fpInstance = flatpickr("#datePicker", {
            mode: "range",
            dateFormat: "d/m/Y",
            animate: true,
            locale: "vn",
            onClose: function (selectedDates, dateStr, instance) {
                if (selectedDates.length === 2) {
                    var fmt = function (d) {
                        var dd   = String(d.getDate()).padStart(2, '0');
                        var mm   = String(d.getMonth() + 1).padStart(2, '0');
                        var yyyy = d.getFullYear();
                        return dd + '/' + mm + '/' + yyyy;
                    };
                    
                    $('#datePicker').val(fmt(selectedDates[0]) + ' - ' + fmt(selectedDates[1]));
                    
                    LoadList(0, 0);
                    LoadSummary();
                } else if (selectedDates.length === 1) {
                    instance.open();
                }
            }
        });

        $('#btnLichHen').click(function () { setActiveType(2); });
        $('#btnDichVu').click(function () { setActiveType(3); });
        $('#btnThanhToan').click(function () { setActiveType(4); });
        $('#btnExportExcel').click(function () { ExportExcel(); });

        $('#selectExample').change(function () {
            applySelectDate();
        });

        applySelectDate();
    });


        function getPickedDates() {
            if (!fpInstance) return { startDate: null, endDate: null };
            var dates = fpInstance.selectedDates;
            if (dates.length >= 2) {
                var end = new Date(dates[1]);
                end.setHours(23, 59, 59, 997);
                return {
                    startDate: formatDateISO(dates[0]),
                    endDate:   formatDateISO(end)
                };
            }
            return {
                startDate: dates.length >= 1 ? formatDateISO(dates[0]) : null,
                endDate:   null
            };
        }

        function formatDateISO(d) {
            var dd   = String(d.getDate()).padStart(2, '0');
            var mm   = String(d.getMonth() + 1).padStart(2, '0');
            var yyyy = d.getFullYear();
            var hh   = String(d.getHours()).padStart(2, '0');
            var mi   = String(d.getMinutes()).padStart(2, '0');
            var ss   = String(d.getSeconds()).padStart(2, '0');
            var ms   = String(d.getMilliseconds()).padStart(3, '0');
            return yyyy + '-' + mm + '-' + dd + 'T' + hh + ':' + mi + ':' + ss + '.' + ms;
        }

        function ClearDate() {
            if (!fpInstance) return;
            fpInstance.clear();                                          
            document.getElementById('datePicker').value = '';           
            document.getElementById('selectExample').value = '0';
            applySelectDate();
        }

        function applySelectDate() {
            var val = parseInt(document.getElementById('selectExample').value);
            var today = new Date();
            var startDate, endDate;

            if (val === 0) {
                startDate = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                endDate   = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59);
            } else {
                endDate   = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59);
                startDate = new Date(today.getFullYear(), today.getMonth() - val, today.getDate());
            }
            if (fpInstance) {
                fpInstance.setDate([startDate, endDate], false);
            }

            var fmt = function (d) {
                var dd   = String(d.getDate()).padStart(2, '0');
                var mm   = String(d.getMonth() + 1).padStart(2, '0');
                var yyyy = d.getFullYear();
                return dd + '/' + mm + '/' + yyyy;
            };
            document.getElementById('datePicker').value = fmt(startDate) + ' - ' + fmt(endDate);
            LoadList(0, 0);
            LoadSummary();
        }

        function setActiveType(type) {
            $('#btnLichHen, #btnDichVu, #btnThanhToan').removeClass('btn-primary text-white border-2 fw-bold').addClass('btn-secondary text-secondary bg-white');

            if (currentType === type) {
                currentType = 1;
            } else {
                currentType = type;
                let btnId = (type === 2) ? 'btnLichHen' : (type === 3) ? 'btnDichVu' : (type === 4) ? 'btnThanhToan' : null;
                if (btnId) {
                    $('#' + btnId).removeClass('btn-secondary text-secondary bg-white border-2 fw-bold').addClass('btn-primary text-primary bg-white border-2 fw-bold');
                }
            }

            LoadList(0, 0);
            LoadSummary();
        }

        function AjaxLoad(url, data, async, error, success, before, complete) {
            $.ajax({
                type: "POST",
                url: url
                , data: data
                , async: async
                , beforeSend: function (xhr) {
                    xhr.setRequestHeader("RequestVerificationToken",
                        $('input:hidden[name="__RequestVerificationToken"]').val());
                    if (before) before();
                }
                , success: function (res) {
                    if (success) success(res);
                }
                , error: function (err) {
                    if (error) error(err);
                    else console.error("Ajax Error:", err);
                }
                , complete: function () {
                    if (complete) complete();
                }
            });
        };

        function LoadList(currentID = 0, isLoadMore = 0) {
            if (currentID == 0 && isLoadMore == 0) {
                dataList      = [];
                beginID       = 0;
                isDoneLoadMore = false;
                $("#lstCustomer").empty();
            }

            var dates = getPickedDates();

            var type = currentType;

            AjaxLoad(
                url    = "/CustomerDashBoard/CustomerDashBoard/?handler=LoadList",
                data   = {
                    "BeginID":   beginID,
                    "Limit":     limit,
                    "Type":      type,
                    "StartDate": dates.startDate,
                    "EndDate":   dates.endDate
                },
                async  = true,
                error  = null,
                success = function (res) {
                    if (res == "-100") {
                        alert("Ngày kết thúc không được nhỏ hơn ngày bắt đầu!");
                        return;
                    }

                    if (res != "[]") {
                        let data = JSON.parse(res);

                        if (currentID == 0) {
                            dataList = dataList.concat(data);
                            beginID  = data[data.length - 1].ID;

                            RenderData(data, "lstCustomer", dataList.length - data.length);
                            ReIndexSTT();

                            $("#itemCount").text(dataList.length);

                            if (data.length < limit) {
                                $("#btnLoadMore").hide();
                                isDoneLoadMore = true;
                            } else {
                                $("#btnLoadMore").show();
                            }
                        } else {
                            if (data && data.length > 0) {
                                if ($('#row_customer_' + currentID).length > 0) {
                                    let index = dataList.findIndex(x => x.ID == data[0].ID);
                                    if (index != -1) dataList[index] = data[0];
                                    $('#row_customer_' + currentID).replaceWith(RenderItem(data[0]));
                                } else {
                                    dataList.push(data[0]);
                                    $('#lstCustomer').prepend(RenderItem(data[0]));
                                }
                                ReIndexSTT();
                            }

                            $("#itemCount").text(dataList.length);
                        }

                    }

                    if (res == "[]") {
                        if (isLoadMore == 1) {
                            isDoneLoadMore = true;
                            $("#btnLoadMore").hide();
                        } else {
                            if (currentID != 0) {
                                if ($('#row_customer_' + currentID).length > 0) {
                                    dataList = dataList.filter(x => x.ID != currentID);
                                    $('#row_customer_' + currentID).remove();
                                    ReIndexSTT();
                                    $("#itemCount").text(dataList.length);
                                }
                            }
                        }
                    }
                },
                before = function () {
                    $("#waitingDiv").show();
                    $("#btnLoadMore").prop('disabled', true);
                },
                complete = function () {
                    $("#waitingDiv").hide();
                    $("#btnLoadMore").prop('disabled', false);
                }
            );
        };

        function LoadSummary() {
            var dates = getPickedDates();

            AjaxLoad(
                url    = "/CustomerDashBoard/CustomerDashBoard/?handler=LoadSummary",
                data   = {
                    "StartDate": dates.startDate,
                    "EndDate":   dates.endDate
                },
                async  = true,
                error  = null,
                success = function (res) {
                    if (res == "-100") {
                        $("#cardSale").text("--");
                        $("#cardRevenue").text("--");
                        $("#cardTotalCustomer").text("--");
                        return;
                    }

                    if (res == "[]" || res == "0") {
                        $("#cardSale").text("0 đ");        
                        $("#cardRevenue").text("0 đ");
                        $("#cardTotalCustomer").text("0");
                        return;
                    }

                    try {
                        var data = JSON.parse(res);
                        if (data && data.length > 0) {
                            var d = data[0];
                            $("#cardSale").text(FormatNumber(d.Sale) + "đ");
                            $("#cardRevenue").text(FormatNumber(d.Revenue) + "đ"); 
                            $("#cardTotalCustomer").text(FormatNumber(d.TotalCustomer));
                        }
                    } catch (e) {
                        console.error("LoadSummary parse error:", e);
                    }
                },
                before = function () {
                    $("#cardSale").text("...");
                    $("#cardRevenue").text("...");
                    $("#cardTotalCustomer").text("...");
                },
                complete = null
            );
        }

        function FormatNumber(value) {
            if (value == null || value === '') return '0';
            var num = parseFloat(value);
            if (isNaN(num)) return '0';
            return num.toLocaleString('vi-VN');
        }

        function RenderItem(item, stt = '') {
            let tr =
            `
                <tr id="row_customer_${item.ID}" data-ID="${item.ID}">
                    <td class="text-center fw-semibold text-dark stt-cell align-middle">${stt}</td>
                    <td class="align-middle">
                        <div class="fw-bold text-dark" style="font-size: 14px;">${item.Name || ''}</div>
                        <div class="text-secondary" style="font-size: 13px;">${item.Note || ''}</div>
                    </td>
                    <td class="text-dark align-middle">${item.Phone1 || ''}</td>
                </tr>
            `;
            return tr;
        }

        function RenderData(data, elementId, offset = 0) {
            let node    = $('#' + elementId);
            let rowData = '';
            for (let i = 0; i < data.length; i++) {
                rowData += RenderItem(data[i], offset + i + 1);
            }
            node.append(rowData);
        }

        function ReIndexSTT() {
            $('#lstCustomer tr').each(function (index) {
                $(this).find('.stt-cell').text(index + 1);
            });
        }

        function ExportExcel() {
            if (!dataList || dataList.length === 0) {
                alert('Không có dữ liệu để xuất file excel');
                return;
            }

            var btn = document.getElementById('btnExportExcel');
            btn.disabled = true;
            btn.innerHTML = `
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="spin-icon">
                    <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                </svg>
                Đang xuất...
            `;

            try {
                var rows = dataList.map(function (item, index) {
                    return {
                        'STT':           index + 1,
                        'Họ tên':        item.Name   || '',
                        'Số điện thoại': item.Phone1 || '',
                        'Ghi chú':       item.Note   || ''
                    };
                });

                var ws = XLSX.utils.json_to_sheet(rows);

                ws['!cols'] = [
                    { wch: 6  }, 
                    { wch: 28 },
                    { wch: 18 },  
                    { wch: 35 } 
                ];

                var wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Danh sách khách hàng');

                var now    = new Date();
                var pad    = function (n) { return String(n).padStart(2, '0'); };
                var stamp  = now.getFullYear() + pad(now.getMonth() + 1) + pad(now.getDate())
                           + '_' + pad(now.getHours()) + pad(now.getMinutes()) + pad(now.getSeconds());
                var fileName = 'DanhSachKhachHang_' + stamp + '.xlsx';

                XLSX.writeFile(wb, fileName);
            } catch (e) {
                console.error('ExportExcel error:', e);
                alert('Xuất file thất bại, vui lòng thử lại!');
            } finally {
                btn.disabled = false;
                btn.innerHTML = `
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.0" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 15V3m0 12l-4-4m4 4l4-4"/>
                        <path d="M2 17v2a2 2 0 002 2h16a2 2 0 002-2v-2"/>
                    </svg>
                `;
            }
        }

    </script>
