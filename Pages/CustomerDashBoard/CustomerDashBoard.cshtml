@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
    <script>
        let beginID       = 0;
        let dataList      = [];
        let limit         = 20;
        let isDoneLoadMore = false;
        let currentType   = 1;          // 1=Customer | 2=LịchHẹn | 3=DịchVụ | 4=ThanhToán
        let fpInstance    = null;       

        $(document).ready(function () {
        fpInstance = flatpickr("#datePicker", {
            mode: "range",
            dateFormat: "d/m/Y",
            animate: true,
            locale: "vn",
            onClose: function (selectedDates, dateStr, instance) {
                if (selectedDates.length === 2) {
                    var fmt = function (d) {
                        var dd   = String(d.getDate()).padStart(2, '0');
                        var mm   = String(d.getMonth() + 1).padStart(2, '0');
                        var yyyy = d.getFullYear();
                        return dd + '/' + mm + '/' + yyyy;
                    };
                    
                    $('#datePicker').val(fmt(selectedDates[0]) + ' - ' + fmt(selectedDates[1]));
                    
                    LoadList(0, 0);
                } else if (selectedDates.length === 1) {
                    instance.open();
                }
            }
        });

        $('#btnKhachHang').click(function () { setActiveType(1); });
        $('#btnLichHen').click(function () { setActiveType(2); });
        $('#btnDichVu').click(function () { setActiveType(3); });
        $('#btnThanhToan').click(function () { setActiveType(4); });
        $('#btnExportExcel').click(async function () {
            await ExportExcel(dataList, false, this);
        });

        $('#btnExportExcelAll').click(async function () {
            await ExportExcel(null, true, this);
        });

        $('#selectExample').change(function () {
            applySelectDate();
        });

        let initBtnId = (currentType === 1) ? 'btnKhachHang' : (currentType === 2) ? 'btnLichHen' : (currentType === 3) ? 'btnDichVu' : (currentType === 4) ? 'btnThanhToan' : null;
        if (initBtnId) {
            $('#' + initBtnId).removeClass('btn-secondary text-secondary bg-white').addClass('btn-primary text-primary bg-white border-2 fw-bold');
        }

        applySelectDate();
    });


        function getPickedDates() {
            if (!fpInstance) return { startDate: null, endDate: null };
            var dates = fpInstance.selectedDates;
            if (dates.length >= 2) {
                var end = new Date(dates[1]);
                end.setHours(23, 59, 59, 997);
                return {
                    startDate: formatDateISO(dates[0]),
                    endDate:   formatDateISO(end)
                };
            }
            return {
                startDate: dates.length >= 1 ? formatDateISO(dates[0]) : null,
                endDate:   null
            };
        }

        function formatDateISO(d) {
            var dd   = String(d.getDate()).padStart(2, '0');
            var mm   = String(d.getMonth() + 1).padStart(2, '0');
            var yyyy = d.getFullYear();
            var hh   = String(d.getHours()).padStart(2, '0');
            var mi   = String(d.getMinutes()).padStart(2, '0');
            var ss   = String(d.getSeconds()).padStart(2, '0');
            var ms   = String(d.getMilliseconds()).padStart(3, '0');
            return yyyy + '-' + mm + '-' + dd + 'T' + hh + ':' + mi + ':' + ss + '.' + ms;
        }

        function ClearDate() {
            if (!fpInstance) return;
            fpInstance.clear();                                          
            document.getElementById('datePicker').value = '';           
            document.getElementById('selectExample').value = '0';
            applySelectDate();
        }

        function applySelectDate() {
            var val = parseInt(document.getElementById('selectExample').value);
            var today = new Date();
            var startDate, endDate;

            if (val === 0) {
                startDate = new Date(today.getFullYear(), today.getMonth(), today.getDate());
                endDate   = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59);
            } else {
                endDate   = new Date(today.getFullYear(), today.getMonth(), today.getDate(), 23, 59, 59);
                startDate = new Date(today.getFullYear(), today.getMonth() - val, today.getDate());
            }
            if (fpInstance) {
                fpInstance.setDate([startDate, endDate], false);
            }

            var fmt = function (d) {
                var dd   = String(d.getDate()).padStart(2, '0');
                var mm   = String(d.getMonth() + 1).padStart(2, '0');
                var yyyy = d.getFullYear();
                return dd + '/' + mm + '/' + yyyy;
            };
            document.getElementById('datePicker').value = fmt(startDate) + ' - ' + fmt(endDate);
            LoadList(0, 0);
        }

        function setActiveType(type) {
            $('#btnKhachHang, #btnLichHen, #btnDichVu, #btnThanhToan').removeClass('btn-primary text-primary border-2 fw-bold').addClass('btn-secondary text-secondary bg-white');

            if (currentType === type) {
                currentType = 1;
            } else {
                currentType = type;
            }

            let btnId = (currentType === 1) ? 'btnKhachHang' : (currentType === 2) ? 'btnLichHen' : (currentType === 3) ? 'btnDichVu' : (currentType === 4) ? 'btnThanhToan' : null;
            if (btnId) {
                $('#' + btnId).removeClass('btn-secondary text-secondary bg-white').addClass('btn-primary text-primary bg-white border-1 fw-bold');
            }

            LoadList(0, 0);
        }

        function AjaxLoad(url, data, async, error, success, before, complete) {
            $.ajax({
                type: "POST",
                url: url
                , data: data
                , async: async
                , beforeSend: function (xhr) {
                    xhr.setRequestHeader("RequestVerificationToken",
                        $('input:hidden[name="__RequestVerificationToken"]').val());
                    if (before) before();
                }
                , success: function (res) {
                    if (success) success(res);
                }
                , error: function (err) {
                    if (error) error(err);
                    else console.error("Ajax Error:", err);
                }
                , complete: function () {
                    if (complete) complete();
                }
            });
        };

        async function fetchDashboardData(beginID, limit, type, dates) {
            return new Promise((resolve, reject) => {
                AjaxLoad(
                    "/CustomerDashBoard/CustomerDashBoard/?handler=LoadDashboardData",
                    { 
                        "BeginID": beginID
                        , "Limit": limit
                        , "Type": type
                        , "StartDate": dates.startDate
                        , "EndDate": dates.endDate 
                    },
                    true,
                    reject,
                    resolve
                );
            });
        }

        function LoadList(currentID = 0, isLoadMore = 0) {
            if (currentID == 0 && isLoadMore == 0) {
                dataList = [];
                beginID = 0;
                isDoneLoadMore = false;
                $("#lstCustomer").empty();

                $("#cardSale").text("...");
                $("#cardRevenue").text("...");
                $("#cardTotalCustomer").text("...");
                $("#cardSaleFull").text("");
                $("#cardRevenueFull").text("");
            }

            var dates = getPickedDates();
            var type = currentType;

            AjaxLoad(
                url = "/CustomerDashBoard/CustomerDashBoard/?handler=LoadDashboardData",
                data = {
                    "BeginID": beginID,
                    "Limit": limit,
                    "Type": type,
                    "StartDate": dates.startDate,
                    "EndDate": dates.endDate
                },
                async = true,
                error = null,
                success = function (res) {
                    if (res == "-100" || res == "-102") {
                        alert(res == "-100" ? "Ngày kết thúc không được nhỏ hơn ngày bắt đầu!" : "Vui lòng chọn ngày hợp lệ!");
                        if (beginID == 0) {
                            $("#cardSale, #cardRevenue, #cardTotalCustomer").text("--");
                            $("#cardSaleFull, #cardRevenueFull").text("");
                        }
                        return;
                    }

                    if (res == "0") {
                        alert("Lỗi hệ thống khi tải dữ liệu!");
                        return;
                    }

                    if (res != "[]") {
                        let responseData = JSON.parse(res);

                        if (beginID == 0) {
                            let sumData = responseData.summary;
                            if (sumData && sumData.length > 0) {
                                var d = sumData[0];
                                $("#cardSale").text(FormatCurrencyShort(d.Sale));
                                $("#cardSaleFull").text(FormatNumber(d.Sale) + " đ");
                                $("#cardRevenue").text(FormatCurrencyShort(d.Revenue));
                                $("#cardRevenueFull").text(FormatNumber(d.Revenue) + " đ");
                                $("#cardTotalCustomer").text(FormatNumber(d.TotalCustomer));
                            } else {
                                $("#cardSale, #cardRevenue").text("0 đ");
                                $("#cardTotalCustomer").text("0");
                                $("#cardSaleFull, #cardRevenueFull").text("");
                            }
                        }

                        let data = responseData.list;

                        if (data && data.length > 0) {
                            if (currentID == 0) {
                                dataList = dataList.concat(data);
                                beginID = data[data.length - 1].ID;

                                RenderData(data, "lstCustomer", dataList.length - data.length);
                                ReIndexSTT();

                                $("#itemCount").text(dataList.length);

                                if (data.length < limit) {
                                    $("#btnLoadMore").hide();
                                    isDoneLoadMore = true;
                                } else {
                                    $("#btnLoadMore").show();
                                }
                            } else {
                                if ($('#row_customer_' + currentID).length > 0) {
                                    let index = dataList.findIndex(x => x.ID == data[0].ID);
                                    if (index != -1) dataList[index] = data[0];
                                    $('#row_customer_' + currentID).replaceWith(RenderItem(data[0]));
                                } else {
                                    dataList.push(data[0]);
                                    $('#lstCustomer').prepend(RenderItem(data[0]));
                                }
                                ReIndexSTT();
                                $("#itemCount").text(dataList.length);
                            }
                        } else {
                            if (isLoadMore == 1) {
                                isDoneLoadMore = true;
                                $("#btnLoadMore").hide();
                            } else if (currentID != 0) {
                                if ($('#row_customer_' + currentID).length > 0) {
                                    dataList = dataList.filter(x => x.ID != currentID);
                                    $('#row_customer_' + currentID).remove();
                                    ReIndexSTT();
                                    $("#itemCount").text(dataList.length);
                                }
                            }
                        }
                    }
                },
                before = function () {
                    $("#waitingDiv").show();
                    $("#btnLoadMore").prop('disabled', true);
                },
                complete = function () {
                    $("#waitingDiv").hide();
                    $("#btnLoadMore").prop('disabled', false);
                }
            );
        };

        function FormatNumber(value) {
            if (value == null || value === '') return '0';
            var num = parseFloat(value);
            if (isNaN(num)) return '0';
            return num.toLocaleString('vi-VN');
        }

        function FormatCurrencyShort(value) {
            if (value == null || value === '') return '0 đ';
            var num = parseFloat(value);
            if (isNaN(num)) return '0 đ';
            
            if (num >= 1000000000) {
                let ty = num / 1000000000;
                let tyStr = ty.toFixed(2);
                let parts = tyStr.split('.');
                let decimalPart = parts[1];
                if (decimalPart === '00') return parts[0] + 'Tỷ';
                if (decimalPart.endsWith('0')) decimalPart = decimalPart[0];
                return parts[0] + 'Tỷ' + decimalPart;
            } else if (num >= 1000000) {
                let tr = num / 1000000;
                let trStr = tr.toFixed(2);
                let parts = trStr.split('.');
                let decimalPart = parts[1];
                if (decimalPart === '00') return parts[0] + 'Tr';
                if (decimalPart.endsWith('0')) decimalPart = decimalPart[0];
                return parts[0] + 'Tr' + decimalPart;
            } else {
                return num.toLocaleString('vi-VN') + ' đ';
            }
        }

        function RenderItem(item, stt = '') {
            let tr =
            `
                <tr id="row_customer_${item.ID}" data-ID="${item.ID}">
                    <td class="text-center fw-semibold text-dark stt-cell align-middle">${stt}</td>
                    <td class="align-middle">
                        <div class="fw-bold text-dark" style="font-size: 14px;">${item.Name || ''}</div>
                        <div class="text-secondary" style="font-size: 13px;">${item.Note || ''}</div>
                    </td>
                    <td class="text-dark align-middle">${item.Phone1 || ''}</td>
                </tr>
            `;
            return tr;
        }

        function RenderData(data, elementId, offset = 0) {
            let node    = $('#' + elementId);
            let rowData = '';
            for (let i = 0; i < data.length; i++) {
                rowData += RenderItem(data[i], offset + i + 1);
            }
            node.append(rowData);
        }

        function ReIndexSTT() {
            $('#lstCustomer tr').each(function (index) {
                $(this).find('.stt-cell').text(index + 1);
            });
        }

        async function ExportExcel(data = null, isLoadAll = false, btnElement = null) {
            let exportData = data;
            let originalHtml = '';

            if (btnElement) {
                originalHtml = $(btnElement).html();
                $(btnElement).prop('disabled', true);
                $(btnElement).html(`<span class="spinner-border spinner-border-sm"></span> ${isLoadAll ? 'Đang tải...' : 'Đang xuất...'}`);
            }

            try {
                if (isLoadAll) {
                    const dates = getPickedDates();

                    const res = await new Promise((resolve, reject) => {
                        AjaxLoad(
                            "/CustomerDashBoard/CustomerDashBoard/?handler=LoadDashboardData",
                            {
                                "BeginID": 0,
                                "Limit": 50000,
                                "Type": currentType,
                                "StartDate": dates.startDate,
                                "EndDate": dates.endDate
                            },
                            true,     
                            reject,   
                            resolve
                        );
                    });

                    if (res == "-100" || res == "-102" || res == "0") {
                        throw new Error("Lỗi máy chủ hoặc ngày tháng không hợp lệ!");
                    }

                    let fullData = JSON.parse(res);
                    exportData = fullData.list;
                }

                if (!exportData || !Array.isArray(exportData) || exportData.length === 0) {
                    alert('Không có dữ liệu để xuất file excel');
                    return false;
                }

                if (btnElement && isLoadAll) {
                    $(btnElement).html(`<span class="spinner-border spinner-border-sm"></span> Đang xuất...`);
                }

                const headerDictionary = {
                    'Name': 'Họ tên',
                    'Phone1': 'Số điện thoại',
                    'Note': 'Ghi chú'
                };

                const rows = exportData.map((item, index) => {
                    let rowData = { 'STT': index + 1 };
                    for (let key in item) {
                        if (key === 'ID') continue;
                        let headerName = headerDictionary[key] || key;
                        let value = (item[key] ?? '');

                        if (key.toLowerCase().includes('phone') && value !== '') {
                            value = String(value);
                        }
                        rowData[headerName] = value;
                    }
                    return rowData;
                });

                const ws = XLSX.utils.json_to_sheet(rows);
                const colWidths = Object.keys(rows[0] || {}).map(key => {
                    let maxLen = Math.max(key.length, ...rows.map(r => String(r[key] || '').length));
                    return { wch: maxLen + 2 };
                });
                ws['!cols'] = colWidths;

                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Danh sách khách hàng');

                const stamp = new Date().toISOString().replace(/[-T:]/g, '').split('.')[0].replace(/\d{2}$/, '');
                XLSX.writeFile(wb, `DanhSachKhachHang_${stamp}.xlsx`);

                return true;
            } catch (error) {
                console.error('ExportExcel Error:', error);
                alert("Lỗi: " + (error.message || 'Có lỗi xảy ra trong quá trình xuất Excel!'));
                return false;
            } finally {
                if (btnElement) {
                    $(btnElement).prop('disabled', false);
                    $(btnElement).html(originalHtml);
                }
            }
        }
    </script>
}
